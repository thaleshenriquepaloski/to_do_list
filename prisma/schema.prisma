generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id       String  @id @default(uuid())
  email    String  @unique
  password String
  name     String?
  todos    Todo[]
}

model Todo {
  id          Int      @id @default(autoincrement())
  description String
  priority    String
  deadline    DateTime
  completed   Boolean  @default(false)
  createdAt   DateTime @default(now())
  userId      String
  user        User     @relation(fields: [userId], references: [id])
}
